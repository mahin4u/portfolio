# ---------------------------------------------------------------------------
# Copy to `.env.local` for local dev, and set the same vars in Netlify
# (Site settings → Environment variables). All are OPTIONAL: without them the
# site still builds and serves the built-in static content — the admin CMS
# simply stays read-only until they're set.
# ---------------------------------------------------------------------------

# Neon Postgres connection string (https://neon.tech → project → Connection).
# Enables the admin CMS to persist changes. The Netlify Neon integration may
# instead provide NETLIFY_DATABASE_URL, which is also picked up automatically.
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Password for the /admin login. Required to use the admin.
ADMIN_PASSWORD="change-me-to-a-long-random-string"

# Secret used to sign admin session cookies. Defaults to ADMIN_PASSWORD if
# unset, but set a separate long random value in production.
SESSION_SECRET="another-long-random-string"
